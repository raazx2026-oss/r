<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="200dp"
    android:background="@color/bg_top" android:gravity="bottom"
    android:orientation="vertical" android:padding="20dp">

    <ImageView android:layout_width="80dp" android:layout_height="80dp"
        android:src="@mipmap/ic_launcher_round" android:layout_marginBottom="12dp"/>
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Zikr &amp; Social App" android:textColor="@color/gold"
        android:textSize="20sp" android:textStyle="bold"/>
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Welcome to the community" android:textColor="@color/text_gray" />
</LinearLayout>
